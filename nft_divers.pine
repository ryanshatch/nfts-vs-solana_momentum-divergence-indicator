//@version=6
indicator("NFT Divers", overlay = false, precision = 3, dynamic_requests = true)

// =============================================================================
// Developer Notes
// =============================================================================
// @Title: NFT Momentum Divergence vs SOL
// @Description: Compares selected basket flow vs SOL momentum with basket modes
// @Author: Ryanshatch
// @Version: 3.3
// @License: Private
// @Websites: https://imacl.one | https://zencrypt.tech | https://ryanshatch.com

// =============================================================================
// Basket Constants
// =============================================================================
B_CORE = 0
B_MEME = 1
B_DEFI = 2

// =============================================================================
// Inputs
// =============================================================================
group_mode = "Basket Mode"
basket_mode = input.string(
     "Core NFT",
     "Mode",
     options = ["Core NFT", "Meme", "Solana DeFi", "Blend Enabled Baskets"],
     group = group_mode)

blend_core = input.bool(true,  "Blend: Include Core NFT",    group = group_mode)
blend_meme = input.bool(false, "Blend: Include Meme",        group = group_mode)
blend_defi = input.bool(false, "Blend: Include Solana DeFi", group = group_mode)

group_syms_base = "Base"
sol_tkr = input.symbol("SOLUSDT", "Solana", group = group_syms_base)

// =============================================================================
// Core NFT Basket Symbols
// =============================================================================
group_core_syms = "Core NFT Basket Symbols"
imx_sym    = input.symbol("IMXUSDT",    "1. IMX",    group = group_core_syms)
blur_sym   = input.symbol("BLURUSDT",   "2. BLUR",   group = group_core_syms)
me_sym     = input.symbol("MEUSDT",     "3. ME",     group = group_core_syms)
tnsr_sym   = input.symbol("TNSRUSDT",   "4. TNSR",   group = group_core_syms)
ron_sym    = input.symbol("RONUSDT",    "5. RON",    group = group_core_syms)
pixel_sym  = input.symbol("PIXELUSDT",  "6. PIXEL",  group = group_core_syms)
ygg_sym    = input.symbol("YGGUSDT",    "7. YGG",    group = group_core_syms)
sand_sym   = input.symbol("SANDUSDT",   "8. SAND",   group = group_core_syms)
gala_sym   = input.symbol("GALAUSDT",   "9. GALA",   group = group_core_syms)
ape_sym    = input.symbol("APEUSDT",    "10. APE",   group = group_core_syms)
pyr_sym    = input.symbol("PYRUSDT",    "11. PYR",   group = group_core_syms)
atlas_sym  = input.symbol("ATLASUSDT",  "12. ATLAS", group = group_core_syms)
audio_sym  = input.symbol("AUDIOUSDT",  "13. AUDIO", group = group_core_syms)
dust_sym   = input.symbol("DUSTUSDT",   "14. DUST",  group = group_core_syms)
jewel_sym  = input.symbol("JEWELUSDT",  "15. JEWEL", group = group_core_syms)
mtvt_sym   = input.symbol("MTVTUSDT",   "16. MTVT",  group = group_core_syms)
dar_sym    = input.symbol("DARUSDT",    "17. DAR",   group = group_core_syms)
// hoodie_sym = input.string("",           "18. HOODIE (manual / optional)", group = group_core_syms)
wild_sym   = input.symbol("WILDUSDT",   "19. WILD",  group = group_core_syms)
floki_sym  = input.symbol("FLOKIUSDT",  "20. FLOKI", group = group_core_syms)
axs_sym    = input.symbol("AXSUSDT",    "21. AXS",   group = group_core_syms)
mana_sym   = input.symbol("MANAUSDT",   "22. MANA",  group = group_core_syms)

// =============================================================================
// Meme Basket Symbols
// =============================================================================
group_meme_syms = "Meme Basket Symbols"
bonk_sym  = input.symbol("BONKUSDT",  "1. BONK",  group = group_meme_syms)
mew_sym   = input.symbol("MEWUSDT",   "2. MEW",   group = group_meme_syms)
pengu_sym = input.symbol("PENGUUSDT", "3. PENGU", group = group_meme_syms)
wen_sym   = input.symbol("WENUSDT",   "4. WEN",   group = group_meme_syms)

// =============================================================================
// Solana DeFi Basket Symbols
// =============================================================================
group_defi_syms = "Solana DeFi Basket Symbols"
jup_sym  = input.symbol("JUPUSDT",  "1. JUP",  group = group_defi_syms)
ray_sym  = input.symbol("RAYUSDT",  "2. RAY",  group = group_defi_syms)
orca_sym = input.symbol("ORCAUSDT", "3. ORCA", group = group_defi_syms)
jlp_sym  = input.symbol("JLPUSD",   "4. JLP",  group = group_defi_syms)

// =============================================================================
// Weights
// =============================================================================
group_core_w = "Weights • Core NFT"
w_imx    = input.float(1.0, "Weight IMX",    minval = 0.0, step = 0.25, group = group_core_w)
w_blur   = input.float(1.0, "Weight BLUR",   minval = 0.0, step = 0.25, group = group_core_w)
w_me     = input.float(1.0, "Weight ME",     minval = 0.0, step = 0.25, group = group_core_w)
w_tnsr   = input.float(1.0, "Weight TNSR",   minval = 0.0, step = 0.25, group = group_core_w)
w_ron    = input.float(1.0, "Weight RON",    minval = 0.0, step = 0.25, group = group_core_w)
w_pixel  = input.float(1.0, "Weight PIXEL",  minval = 0.0, step = 0.25, group = group_core_w)
w_ygg    = input.float(1.0, "Weight YGG",    minval = 0.0, step = 0.25, group = group_core_w)
w_sand   = input.float(1.0, "Weight SAND",   minval = 0.0, step = 0.25, group = group_core_w)
w_gala   = input.float(1.0, "Weight GALA",   minval = 0.0, step = 0.25, group = group_core_w)
w_ape    = input.float(1.0, "Weight APE",    minval = 0.0, step = 0.25, group = group_core_w)
w_pyr    = input.float(1.0, "Weight PYR",    minval = 0.0, step = 0.25, group = group_core_w)
w_atlas  = input.float(1.0, "Weight ATLAS",  minval = 0.0, step = 0.25, group = group_core_w)
w_audio  = input.float(1.0, "Weight AUDIO",  minval = 0.0, step = 0.25, group = group_core_w)
w_dust   = input.float(1.0, "Weight DUST",   minval = 0.0, step = 0.25, group = group_core_w)
w_jewel  = input.float(1.0, "Weight JEWEL",  minval = 0.0, step = 0.25, group = group_core_w)
w_mtvt   = input.float(1.0, "Weight MTVT",   minval = 0.0, step = 0.25, group = group_core_w)
w_dar    = input.float(1.0, "Weight DAR",    minval = 0.0, step = 0.25, group = group_core_w)
// w_hoodie = input.float(0.0, "Weight HOODIE", minval = 0.0, step = 0.25, group = group_core_w)
w_wild   = input.float(1.0, "Weight WILD",   minval = 0.0, step = 0.25, group = group_core_w)
w_floki  = input.float(1.0, "Weight FLOKI",  minval = 0.0, step = 0.25, group = group_core_w)
w_axs    = input.float(1.0, "Weight AXS",    minval = 0.0, step = 0.25, group = group_core_w)
w_mana   = input.float(1.0, "Weight MANA",   minval = 0.0, step = 0.25, group = group_core_w)

group_meme_w = "Weights • Meme"
w_bonk  = input.float(1.0, "Weight BONK",  minval = 0.0, step = 0.25, group = group_meme_w)
w_mew   = input.float(1.0, "Weight MEW",   minval = 0.0, step = 0.25, group = group_meme_w)
w_pengu = input.float(1.0, "Weight PENGU", minval = 0.0, step = 0.25, group = group_meme_w)
w_wen   = input.float(1.0, "Weight WEN",   minval = 0.0, step = 0.25, group = group_meme_w)

group_defi_w = "Weights • Solana DeFi"
w_jup  = input.float(1.0, "Weight JUP",  minval = 0.0, step = 0.25, group = group_defi_w)
w_ray  = input.float(1.0, "Weight RAY",  minval = 0.0, step = 0.25, group = group_defi_w)
w_orca = input.float(1.0, "Weight ORCA", minval = 0.0, step = 0.25, group = group_defi_w)
w_jlp  = input.float(1.0, "Weight JLP",  minval = 0.0, step = 0.25, group = group_defi_w)

norm_w = input.bool(true, "Normalize by active weight sum", group = group_defi_w)

// =============================================================================
// Calculation
// =============================================================================
group_calc = "Calculation"
len_mom       = input.int(14,  "Momentum Length", minval = 1, group = group_calc)
len_z         = input.int(50,  "Z-Score Length", minval = 2, group = group_calc)
smooth        = input.int(5,   "Smoothing", minval = 1, group = group_calc)
normalize_vol = input.bool(true, "Normalize each symbol by running mean", group = group_calc)
norm_len      = input.int(100, "Per-symbol running mean length", minval = 2, group = group_calc)
use_dollarvol = input.bool(false, "Use close × volume instead of raw volume", group = group_calc)

// =============================================================================
// Colors
// =============================================================================
group_col = "Colors"
c_div   = input.color(color.rgb(24, 215, 72),  "Color Divergence", group = group_col)
c_sol   = input.color(color.rgb(255, 255, 255),  "Color SOL Z",      group = group_col)
c_flow  = input.color(color.rgb(231, 177, 60),   "Color Proxy Flow Z", group = group_col)
c_core  = input.color(color.rgb(70, 130, 180),  "Color Core Basket", group = group_col)
c_meme  = input.color(color.rgb(141, 71, 255),  "Color Meme Basket", group = group_col)
c_defi  = input.color(color.rgb(57, 255, 20),   "Color DeFi Basket", group = group_col)

// =============================================================================
// Helpers
// =============================================================================
zscore_smooth(src, length, smooth_len) =>
    mean_ = ta.sma(src, length)
    dev_  = ta.stdev(src, length)
    z_    = na(dev_) or dev_ == 0 ? na : (src - mean_) / dev_
    ta.sma(z_, smooth_len)

safe_ratio(num, den) =>
    na(num) or na(den) or math.abs(den) <= 0.0000001 ? na : num / den

get_proxy_raw(sym, use_quote_value) =>
    if sym == ""
        na
    else
        if use_quote_value
            request.security(sym, timeframe.period, close * volume, ignore_invalid_symbol = true)
        else
            request.security(sym, timeframe.period, volume, ignore_invalid_symbol = true)

get_proxy_norm(sym, ma_len, use_quote_value) =>
    if sym == ""
        [na, na]
    else
        if use_quote_value
            request.security(sym, timeframe.period, [close * volume, ta.sma(close * volume, ma_len)], ignore_invalid_symbol = true)
        else
            request.security(sym, timeframe.period, [volume, ta.sma(volume, ma_len)], ignore_invalid_symbol = true)

is_basket_enabled(basket_id) =>
    basket_mode == "Core NFT" ? basket_id == B_CORE :
     basket_mode == "Meme" ? basket_id == B_MEME :
     basket_mode == "Solana DeFi" ? basket_id == B_DEFI :
     (basket_id == B_CORE and blend_core) or (basket_id == B_MEME and blend_meme) or (basket_id == B_DEFI and blend_defi)

basket_name(basket_id) =>
    basket_id == B_CORE ? "CORE" : basket_id == B_MEME ? "MEME" : "DEFI"

basket_color(basket_id) =>
    basket_id == B_CORE ? c_core : basket_id == B_MEME ? c_meme : c_defi

// =============================================================================
// Arrays
// =============================================================================
labels = array.from(
    "IMX", "BLUR", "ME", "TNSR", "RON", "PIXEL", "YGG", "SAND", "GALA", "APE", "PYR", "ATLAS", "AUDIO", "DUST", "JEWEL", "MTVT", "DAR", "HOODIE", "WILD", "FLOKI", "AXS", "MANA",
    "BONK", "MEW", "PENGU", "WEN",
    "JUP", "RAY", "ORCA", "JLP"
)

syms = array.from(
    imx_sym, blur_sym, me_sym, tnsr_sym, ron_sym, pixel_sym, ygg_sym, sand_sym, gala_sym, ape_sym, pyr_sym, atlas_sym, audio_sym, dust_sym, jewel_sym, mtvt_sym, dar_sym, wild_sym, floki_sym, axs_sym, mana_sym,
    bonk_sym, mew_sym, pengu_sym, wen_sym,
    jup_sym, ray_sym, orca_sym, jlp_sym
)

wgts = array.from(
    w_imx, w_blur, w_me, w_tnsr, w_ron, w_pixel, w_ygg, w_sand, w_gala, w_ape, w_pyr, w_atlas, w_audio, w_dust, w_jewel, w_mtvt, w_dar, w_wild, w_floki, w_axs, w_mana,
    w_bonk, w_mew, w_pengu, w_wen,
    w_jup, w_ray, w_orca, w_jlp
)

basket_ids = array.from(
    B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE, B_CORE,
    B_MEME, B_MEME, B_MEME, B_MEME,
    B_DEFI, B_DEFI, B_DEFI, B_DEFI
)

// =============================================================================
// SOL Momentum
// =============================================================================
sol_close = request.security(sol_tkr, timeframe.period, close, ignore_invalid_symbol = true)
sol_prev  = sol_close[len_mom]
sol_ret   = na(sol_prev) or sol_prev <= 0 or sol_close <= 0 ? na : math.log(sol_close / sol_prev)
sol_z     = zscore_smooth(sol_ret, len_z, smooth)

// =============================================================================
// Composite Proxy Flow
// =============================================================================
float flow_sum   = 0.0
float weight_sum = 0.0
int active_count = 0

for i = 0 to array.size(syms) - 1
    sym       = array.get(syms, i)
    w         = array.get(wgts, i)
    basket_id = array.get(basket_ids, i)

    if is_basket_enabled(basket_id) and sym != "" and w > 0
        float normalized_flow = na

        if normalize_vol
            [raw_flow, avg_flow] = get_proxy_norm(sym, norm_len, use_dollarvol)
            normalized_flow := safe_ratio(raw_flow, avg_flow)
        else
            normalized_flow := get_proxy_raw(sym, use_dollarvol)

        if not na(normalized_flow)
            flow_sum   += normalized_flow * w
            weight_sum += w
            active_count += 1

composite_flow = active_count == 0 ? na : (norm_w and weight_sum > 0 ? flow_sum / weight_sum : flow_sum)
log_flow       = na(composite_flow) or composite_flow <= 0 ? na : math.log(composite_flow)
v_z            = zscore_smooth(log_flow, len_z, smooth)
div            = v_z - sol_z

// =============================================================================
// Signals
// =============================================================================
lead = ta.crossover(div, 0)
lag  = ta.crossunder(div, 0)

// =============================================================================
// Plots
// =============================================================================
plot(div,   title = "Divergence",   style = plot.style_columns, color = color.new(c_div, 0))
plot(sol_z, title = "SOL Z",        color = color.new(c_sol, 0))
plot(v_z,   title = "Proxy Flow Z", color = color.new(c_flow, 0))
hline(0, "Zero", color = color.gray)

plotshape(lead, title = "Leading", location = location.bottom, style = shape.triangleup,   text = "NFTs", size = size.small, color = color.green)
plotshape(lag,  title = "Lagging", location = location.top, style = shape.triangledown, text = "SOL",  size = size.small, color = color.red)

// =============================================================================
// Stats Table
// =============================================================================
corr = ta.correlation(v_z, sol_z, len_z)
var table t = table.new(position.top_right, 3, 34, border_width = 1)

if barstate.islast
    table.clear(t, 0, 0, 2, 33)

    table.cell(t, 0, 0, "Mode: " + basket_mode, text_color = color.white, bgcolor = color.new(color.rgb(40, 40, 40), 0))
    table.cell(t, 1, 0, "Corr: " + (na(corr) ? "n/a" : str.tostring(corr, "#.###")), text_color = color.white, bgcolor = color.new(color.rgb(40, 40, 40), 0))
    table.cell(t, 2, 0, "Active: " + str.tostring(active_count), text_color = color.white, bgcolor = color.new(color.rgb(40, 40, 40), 0))

    table.cell(t, 0, 1, "Asset",  text_color = color.white, bgcolor = color.new(color.black, 0))
    table.cell(t, 1, 1, "Basket", text_color = color.white, bgcolor = color.new(color.black, 0))
    table.cell(t, 2, 1, "Weight", text_color = color.white, bgcolor = color.new(color.black, 0))

    int row = 2
    for i = 0 to array.size(syms) - 1
        sym       = array.get(syms, i)
        w         = array.get(wgts, i)
        basket_id = array.get(basket_ids, i)

        if is_basket_enabled(basket_id) and sym != "" and w > 0 and row <= 33
            lab  = array.get(labels, i)
            tag  = basket_name(basket_id)
            bcol = basket_color(basket_id)

            table.cell(t, 0, row, lab, text_color = color.white, bgcolor = color.new(bcol, 0))
            table.cell(t, 1, row, tag, text_color = color.white, bgcolor = color.new(bcol, 70))
            table.cell(t, 2, row, str.tostring(w, "#.##"), text_color = color.white, bgcolor = color.new(color.black, 0))
            row += 1

    if row <= 33
        for r = row to 33
            table.cell(t, 0, r, "", text_color = color.white, bgcolor = color.new(color.black, 100))
            table.cell(t, 1, r, "", text_color = color.white, bgcolor = color.new(color.black, 100))
            table.cell(t, 2, r, "", text_color = color.white, bgcolor = color.new(color.black, 100))
