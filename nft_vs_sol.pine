//@version=6
indicator("NFTs vs SOL [Optimized]", overlay = false, precision = 3)

// =============================================================================
// Developer Notes
// =============================================================================
// @NFT Momentum Divergence vs SOL
// @Description: Compares NFT / proxy activity vs SOL momentum
// @Author imaclone_eth / ryanshatch
// @OriginalAuthor imaclone.x
// @License Private
// @Website https://imacl.one

// =============================================================================
// Inputs
// =============================================================================
group_syms = "Symbols"
sol_tkr   = input.symbol("BINANCE:SOLUSDT",  "Solana",   group = group_syms)
blur_sym  = input.symbol("BINANCE:BLURUSDT", "1. BLUR",  group = group_syms)
looks_sym = input.symbol("BINANCE:LOOKSUSDT","2. LOOKS", group = group_syms)
tnsr_sym  = input.symbol("BINANCE:TNSRUSDT", "3. TNSR",  group = group_syms)
magic_sym = input.symbol("BINANCE:MAGICUSDT","4. MAGIC", group = group_syms)
ape_sym   = input.symbol("BINANCE:APEUSDT",  "5. APE",   group = group_syms)
me_sym    = input.symbol("BINANCE:MEUSDT",   "6. ME",    group = group_syms)
pengu_sym = input.symbol("BINANCE:PENGUUSDT","7. PENGU", group = group_syms)
jup_sym   = input.symbol("BINANCE:JUPUSDT",  "8. JUP",   group = group_syms)
sns_sym   = input.symbol("BINANCE:SNSUSDT",  "9. SNS",   group = group_syms)
dbr_sym   = input.symbol("BINANCE:DBRUSDT",  "10. DBR",  group = group_syms)
s_sym     = input.symbol("BINANCE:SUSDT",    "11. S",    group = group_syms)
ada_sym   = input.symbol("BINANCE:ADAUSDT",  "12. ADA",  group = group_syms)
eth_sym   = input.symbol("BINANCE:ETHUSDT",  "13. ETH",  group = group_syms)

group_w = "Weights"
w_blur   = input.float(1.0, "Weight BLUR",  minval = 0.0, step = 0.25, group = group_w)
w_looks  = input.float(1.0, "Weight LOOKS", minval = 0.0, step = 0.25, group = group_w)
w_tnsr   = input.float(1.0, "Weight TNSR",  minval = 0.0, step = 0.25, group = group_w)
w_magic  = input.float(0.0, "Weight MAGIC", minval = 0.0, step = 0.25, group = group_w)
w_ape    = input.float(1.0, "Weight APE",   minval = 0.0, step = 0.25, group = group_w)
w_me     = input.float(1.0, "Weight ME",    minval = 0.0, step = 0.25, group = group_w)
w_pengu  = input.float(1.0, "Weight PENGU", minval = 0.0, step = 0.25, group = group_w)
w_jup    = input.float(1.0, "Weight JUP",   minval = 0.0, step = 0.25, group = group_w)
w_sns    = input.float(1.0, "Weight SNS",   minval = 0.0, step = 0.25, group = group_w)
w_dbr    = input.float(1.0, "Weight DBR",   minval = 0.0, step = 0.25, group = group_w)
w_s      = input.float(1.0, "Weight S",     minval = 0.0, step = 0.25, group = group_w)
w_ada    = input.float(0.0, "Weight ADA",   minval = 0.0, step = 0.25, group = group_w)
w_eth    = input.float(1.0, "Weight ETH",   minval = 0.0, step = 0.25, group = group_w)
norm_w   = input.bool(true, "Normalize by active weight sum", group = group_w)

group_calc = "Calculation"
len_mom       = input.int(14,  "Momentum Length", minval = 1, group = group_calc)
len_z         = input.int(50,  "Z-Score Length", minval = 2, group = group_calc)
smooth        = input.int(5,   "Smoothing", minval = 1, group = group_calc)
normalize_vol = input.bool(true, "Normalize each symbol by running mean", group = group_calc)
norm_len      = input.int(100, "Per-symbol running mean length", minval = 2, group = group_calc)
use_dollarvol = input.bool(false, "Use close × volume instead of raw volume", group = group_calc)

group_col = "Colors"
c_blur   = input.color(color.rgb(24, 198, 215),  "Color BLUR",  group = group_col)
c_looks  = input.color(color.rgb(0, 123, 255),   "Color LOOKS", group = group_col)
c_tnsr   = input.color(color.rgb(241, 196, 15),  "Color TNSR",  group = group_col)
c_magic  = input.color(color.rgb(231, 76, 60),   "Color MAGIC", group = group_col)
c_ape    = input.color(color.rgb(128, 0, 32),    "Color APE",   group = group_col)
c_me     = input.color(color.rgb(231, 76, 60),   "Color ME",    group = group_col)
c_pengu  = input.color(color.rgb(141, 71, 255),  "Color PENGU", group = group_col)
c_jup    = input.color(color.rgb(57, 255, 20),   "Color JUP",   group = group_col)
c_sns    = input.color(color.rgb(10, 25, 74),    "Color SNS",   group = group_col)
c_dbr    = input.color(color.rgb(192, 192, 192), "Color DBR",   group = group_col)
c_s      = input.color(color.rgb(120, 120, 120), "Color S",     group = group_col)
c_ada    = input.color(color.rgb(0, 153, 153),   "Color ADA",   group = group_col)
c_eth    = input.color(color.rgb(100, 100, 110), "Color ETH",   group = group_col)

// =============================================================================
// Helpers
// =============================================================================
zscore_smooth(src, length, smooth_len) =>
    mean_ = ta.sma(src, length)
    dev_  = ta.stdev(src, length)
    z_    = na(dev_) or dev_ == 0 ? na : (src - mean_) / dev_
    ta.sma(z_, smooth_len)

safe_ratio(num, den) =>
    float out = num
    if not na(den)
        if math.abs(den) > 0.0000001
            out := num / den
    out

get_proxy_raw(sym, use_quote_value) =>
    if sym == ""
        0.0
    else
        if use_quote_value
            request.security(sym, timeframe.period, close * volume)
        else
            request.security(sym, timeframe.period, volume)

get_proxy_norm(sym, ma_len, use_quote_value) =>
    if sym == ""
        [0.0, 0.0]
    else
        if use_quote_value
            request.security(sym, timeframe.period, [close * volume, ta.sma(close * volume, ma_len)])
        else
            request.security(sym, timeframe.period, [volume, ta.sma(volume, ma_len)])

// =============================================================================
// Arrays
// =============================================================================
labels = array.from("BLUR", "LOOKS", "TNSR", "MAGIC", "APE", "ME", "PENGU", "JUP", "SNS", "DBR", "S", "ADA", "ETH")
syms   = array.from(blur_sym, looks_sym, tnsr_sym, magic_sym, ape_sym, me_sym, pengu_sym, jup_sym, sns_sym, dbr_sym, s_sym, ada_sym, eth_sym)
wgts   = array.from(w_blur, w_looks, w_tnsr, w_magic, w_ape, w_me, w_pengu, w_jup, w_sns, w_dbr, w_s, w_ada, w_eth)
cols   = array.from(c_blur, c_looks, c_tnsr, c_magic, c_ape, c_me, c_pengu, c_jup, c_sns, c_dbr, c_s, c_ada, c_eth)

// =============================================================================
// SOL Momentum
// =============================================================================
sol_close = request.security(sol_tkr, timeframe.period, close)
sol_prev  = sol_close[len_mom]
sol_ret   = na(sol_prev) or sol_prev <= 0 or sol_close <= 0 ? na : math.log(sol_close / sol_prev)
sol_z     = zscore_smooth(sol_ret, len_z, smooth)

// =============================================================================
// Composite Proxy Flow
// =============================================================================
float flow_sum   = 0.0
float weight_sum = 0.0
int active_count = 0

for i = 0 to array.size(syms) - 1
    sym = array.get(syms, i)
    w   = array.get(wgts, i)

    if sym != "" and w > 0
        float normalized_flow = na

        if normalize_vol
            [raw_flow, avg_flow] = get_proxy_norm(sym, norm_len, use_dollarvol)
            normalized_flow := safe_ratio(raw_flow, avg_flow)
        else
            normalized_flow := get_proxy_raw(sym, use_dollarvol)

        if not na(normalized_flow)
            flow_sum   += normalized_flow * w
            weight_sum += w
            active_count += 1

composite_flow = active_count == 0 ? na : (norm_w and weight_sum > 0 ? flow_sum / weight_sum : flow_sum)
log_flow       = na(composite_flow) or composite_flow <= 0 ? na : math.log(composite_flow)
v_z            = zscore_smooth(log_flow, len_z, smooth)
div            = v_z - sol_z

// =============================================================================
// Signals
// =============================================================================
lead = ta.crossover(div, 0)
lag  = ta.crossunder(div, 0)

// =============================================================================
// Plots
// =============================================================================
plot(div,   title = "Divergence",  style = plot.style_columns, color = color.new(color.rgb(24, 198, 215), 0))
plot(sol_z, title = "SOL Z",       color = color.new(color.rgb(241, 196, 15), 0))
plot(v_z,   title = "Proxy Flow Z", color = color.new(color.rgb(231, 76, 60), 0))
hline(0, "Zero", color = color.gray)

plotshape(lead, title = "Leading", location = location.bottom, style = shape.triangleup,   text = "LEAD", size = size.small, color = color.green)
plotshape(lag,  title = "Lagging", location = location.top,    style = shape.triangledown, text = "LAG",  size = size.small, color = color.red)

// =============================================================================
// Stats Table
// =============================================================================
corr = ta.correlation(v_z, sol_z, len_z)
var table t = table.new(position.top_right, 2, 14, border_width = 1)

if barstate.islast
    table.cell(t, 0, 0, "Corr: " + (na(corr) ? "n/a" : str.tostring(corr, "#.###")), text_color = color.white, bgcolor = color.new(color.rgb(40, 40, 40), 0))
    table.cell(t, 1, 0, "Active (weight)", text_color = color.white, bgcolor = color.new(color.rgb(40, 40, 40), 0))

    row = 1
    for i = 0 to array.size(syms) - 1
        sym = array.get(syms, i)
        w   = array.get(wgts, i)

        if sym != "" and w > 0 and row <= 13
            lab  = array.get(labels, i)
            col_ = array.get(cols, i)

            table.cell(t, 0, row, lab, text_color = color.white, bgcolor = color.new(col_, 0))
            table.cell(t, 1, row, str.tostring(w, "#.##"), text_color = color.white, bgcolor = color.new(color.black, 0))
            row += 1

    if row <= 13
        for r = row to 13
            table.cell(t, 0, r, "", text_color = color.white, bgcolor = color.new(color.black, 100))
            table.cell(t, 1, r, "", text_color = color.white, bgcolor = color.new(color.black, 100))
