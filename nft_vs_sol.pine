//@version=6
indicator('NFTs vs SOL', overlay = false, precision = 3)

// Developer Notes:
//* Version 2.1 - Adding Color Customization Inputs for each token for a better user experience / UI.
// @NFT Momentum Divergence vs SOL
// @LastUpdated 10-14-2025T3:00:00Z
// @Version 1.2
// @Description: Compares NFT dominance vs SOL
// @Author zen silva
// @OriginalAuthor imaclone.x
// @License Private
// @Website https://imacl.one

// === Inputs ===

// Optional: a default exchange prefix to help users quickly use common tickers (set to empty to type full symbols)
exchange_pref = input.string('BINANCE:', 'Default Exchange Prefix (leave blank to input full symbols)')

// Note: TradingView requires a constant string for input.symbol default values.
// You can set your preferred default exchange below as a literal. The `exchange_pref`
// input is left for your convenience but cannot be concatenated into the default.
sol_tkr = input.symbol('BINANCE:SOLUSDT', 'Solana')
blur_sym = input.symbol('', '1. BLUR')
looks_sym = input.symbol('', '2. LOOKS Symbol')
tnsr_sym = input.symbol('', '3. TNSR Symbol')
magic_sym = input.symbol('', '4. MAGIC Symbol')
ape_sym = input.symbol('', '5. APE Symbol')
me_sym = input.symbol('', '6. ME Symbol')
pengu_sym = input.symbol('', '7. PENGU Symbol')

// New requested symbols (add as inputs so user can override full symbol if needed)
jup_sym = input.symbol('', '8. JUP Symbol')
sns_sym = input.symbol('', '9. SNS Symbol')
dbr_sym = input.symbol('', '10. DBR Symbol')
s_sym = input.symbol('', '11. S Symbol')
ada_sym = input.symbol('', '12. ADA Symbol')
eth_sym = input.symbol('', '13. ETH Symbol')


w_blur = input.float(1, 'Weight BLUR')
w_looks = input.float(1, 'Weight LOOKS')
w_tnsr = input.float(1, 'Weight TNSR')
w_magic = input.float(0, 'Weight MAGIC')
w_ape = input.float(1, 'Weight APE')
w_me = input.float(1, 'Weight ME')
w_pengu = input.float(1, 'Weight PENGU')
// Weights for new symbols (default 0)
w_jup = input.float(1, 'Weight JUP')
w_sns = input.float(1, 'Weight SNS')
w_dbr = input.float(1, 'Weight DBR')
w_s = input.float(1, 'Weight S')
w_ada = input.float(0, 'Weight ADA')
w_eth = input.float(1, 'Weight ETH')

len_mom = input.int(14, 'Momentum Length')
len_z = input.int(50, 'Z-Score Length')
smooth = input.int(5, 'Smoothing')
// Normalization inputs
normalize = input.bool(true, 'Normalize per-symbol by running mean')
norm_len = input.int(100, 'Per-symbol running mean length')

// Per-symbol colors (so you can color-coat tokens to match your screenshot)
// Default colors approximated from your screenshot (adjust in inputs as needed)
// BLUR: cyan bars
c_blur = input.color(color.rgb(24,198,215), 'Color BLUR')
// LOOKS: blue
c_looks = input.color(color.rgb(0,123,255), 'Color LOOKS')
// TNSR: yellow (SOL-like)
c_tnsr = input.color(color.rgb(241,196,15), 'Color TNSR')
// MAGIC: magenta-ish
c_magic = input.color(color.rgb(231,76,60), 'Color MAGIC')
// APE: maroon/dark red
c_ape = input.color(color.rgb(128,0,32), 'Color APE')
// ME: red
c_me = input.color(color.rgb(231,76,60), 'Color ME')
// PENGU: purple
c_pengu = input.color(color.rgb(141,71,255), 'Color PENGU')
// JUP: lime
c_jup = input.color(color.rgb(57,255,20), 'Color JUP')
// SNS: navy
c_sns = input.color(color.rgb(10,25,74), 'Color SNS')
// DBR: silver/gray
c_dbr = input.color(color.rgb(192,192,192), 'Color DBR')
// S: neutral gray
c_s = input.color(color.rgb(120,120,120), 'Color S')
// ADA: teal
c_ada = input.color(color.rgb(0,153,153), 'Color ADA')
// ETH: slate gray
c_eth = input.color(color.rgb(100,100,110), 'Color ETH')

// === Data ===
sol_close = request.security(sol_tkr, timeframe.period, close)
proxyVol(sym) =>
    sym == '' ? 0.0 : request.security(sym, timeframe.period, volume)

// Helper to get running mean (SMA) of volume for a symbol via request.security
getMeanVol(sym, length) =>
    sym == '' ? 0.0 : request.security(sym, timeframe.period, ta.sma(volume, length))

// === Calculations ===
sol_mom = ta.roc(sol_close, len_mom)
sol_z = ta.sma((sol_mom - ta.sma(sol_mom, len_z)) / ta.stdev(sol_mom, len_z), smooth)


// Build arrays of symbols and corresponding weights for easier maintenance and single-pass requests
syms = array.from(blur_sym, looks_sym, tnsr_sym, magic_sym, ape_sym, me_sym, pengu_sym, jup_sym, sns_sym, dbr_sym, s_sym, ada_sym, eth_sym)
wgts = array.from(w_blur, w_looks, w_tnsr, w_magic, w_ape, w_me, w_pengu, w_jup, w_sns, w_dbr, w_s, w_ada, w_eth)
cols = array.from(c_blur, c_looks, c_tnsr, c_magic, c_ape, c_me, c_pengu, c_jup, c_sns, c_dbr, c_s, c_ada, c_eth)

v_sum_local = 0.0
// Precompute mean volumes for all symbols by calling getMeanVol once per input symbol
mean_blur = getMeanVol(blur_sym, norm_len)
mean_looks = getMeanVol(looks_sym, norm_len)
mean_tnsr = getMeanVol(tnsr_sym, norm_len)
mean_magic = getMeanVol(magic_sym, norm_len)
mean_ape = getMeanVol(ape_sym, norm_len)
mean_me = getMeanVol(me_sym, norm_len)
mean_pengu = getMeanVol(pengu_sym, norm_len)
mean_jup = getMeanVol(jup_sym, norm_len)
mean_sns = getMeanVol(sns_sym, norm_len)
mean_dbr = getMeanVol(dbr_sym, norm_len)
mean_s = getMeanVol(s_sym, norm_len)
mean_ada = getMeanVol(ada_sym, norm_len)
mean_eth = getMeanVol(eth_sym, norm_len)

mean_vols = array.from(mean_blur, mean_looks, mean_tnsr, mean_magic, mean_ape, mean_me, mean_pengu, mean_jup, mean_sns, mean_dbr, mean_s, mean_ada, mean_eth)

for i = 0 to array.size(syms) - 1
    sym = array.get(syms, i)
    w = array.get(wgts, i)
    // skip empty symbols or zero weights
    if sym != '' and w != 0
        vol = proxyVol(sym)
        mean_vol_local = array.get(mean_vols, i)
        norm_vol_local = 0.0
        if normalize
            // running mean per symbol to normalize volume
            norm_vol_local := mean_vol_local == 0 ? vol : vol / mean_vol_local
        else
            norm_vol_local := vol
        v_sum_local += norm_vol_local * w

v_sum = v_sum_local

log_v = math.log(v_sum + 1e-6)
v_z = ta.sma((log_v - ta.sma(log_v, len_z)) / ta.stdev(log_v, len_z), smooth)
div = v_z - sol_z

// === Signals ===
lead = ta.crossover(div, 0)
lag = ta.crossunder(div, 0)

// === Plots ===
// Use colors matching the screenshot
plot(div, title = 'Divergence', style = plot.style_columns, color = color.new(color.rgb(24,198,215), 0))
plot(sol_z, title = 'SOL Z', color = color.new(color.rgb(241,196,15), 0))
plot(v_z, title = 'Volume Z', color = color.new(color.rgb(231,76,60), 0))
hline(0, 'Zero', color = color.gray)
plotshape(lead, location = location.bottom, style = shape.triangleup, text = 'LEADING', size = size.small, color = color.green)
plotshape(lag, location = location.top, style = shape.triangledown, text = 'LAGGING', size = size.small, color = color.red)

// === Stats Table ===
corr = ta.correlation(v_z, sol_z, len_z)
// Expanded stats table: two columns for label + weight, show correlation on top
// table.new requires constant dimensions; set to 2 columns x 14 rows (header + up to 13 symbols)
var table t = table.new(position.top_right, 2, 14, border_width = 1)
if barstate.islast
    // header row
    table.cell(t, 0, 0, 'Corr: ' + str.tostring(corr, '#.###'), text_color = color.white, bgcolor = color.new(color.rgb(40,40,40), 0))
    table.cell(t, 1, 0, 'Active (weight)', text_color = color.white, bgcolor = color.new(color.rgb(40,40,40), 0))
    labels = array.from('BLUR', 'LOOKS', 'TNSR', 'MAGIC', 'APE', 'ME', 'PENGU', 'JUP', 'SNS', 'DBR', 'S', 'ADA', 'ETH')
    row = 1
    for i = 0 to array.size(syms) - 1
        sym = array.get(syms, i)
        w = array.get(wgts, i)
        lab = array.get(labels, i)
        colc = array.get(cols, i)
        if sym != '' and w != 0
            table.cell(t, 0, row, lab, text_color = color.white, bgcolor = color.new(colc, 0))
            table.cell(t, 1, row, str.tostring(w, '#.###'), text_color = color.white, bgcolor = color.new(color.black, 0))
            row += 1

// ROLLBACK Version 1.0:

// NFTs vs SOL – Momentum Divergence Radar       
// [b]Compares SOL momentum with a composite of NFT-proxy activity, standardized to z-scores, and plots their difference.[/b]

// [b]Method:[/b]
// SOL ROC → z-score and smooth → sol_z. Weighted proxy volumes → log-normalize → z-score and smooth → v_z. Divergence div = v_z − sol_z.

// [b]Readings: [/b]
// div > 0 suggests NFT activity leading SOL; div < 0 suggests lag. Zero-line crosses indicate leadership changes.

// [b]Inputs:[/b]
// $SOL symbol; up to 12 proxy symbols and weights; momentum length; z-score window; smoothing.

// [b]Use: [/b]
// 30m–1D. Treat as context; confirm with trend and structure.
// Limits: Proxy choice and regime shifts affect results.
// [pine][s]Closed-source script.[/s][/pine]

// To request access, send me a TradingView private message with your username.
// I will add or remove users using the Manage Access button on this script’s page.
// No external links, emails, or off-site payments are used here.
//* Version 2.0 - Working Version
// // This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// // © imaclone

